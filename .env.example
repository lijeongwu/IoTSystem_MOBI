MOBI_LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Text model for MOBI's conversation reply.
MOBI_GEMINI_MODEL=gemini-3.5-flash

# Gemini TTS model and voice. Puck is a voice name, not part of the model id.
MOBI_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
MOBI_GEMINI_TTS_VOICE=Puck

# Optional: put a custom system prompt in a separate file.
# MOBI_SYSTEM_PROMPT_FILE=prompts/mobi_system_prompt.txt
